# Copy into Railway → your web service → Variables (then redeploy).
# Grammar names must match Postgres GrammarPoint.name exactly (middle dot is ・ U+30FB).

# Leo (lluan@andrew.cmu.edu) sees only group-1 grammar 「だ・です」:
DEMO_ONLY_GRAMMAR_NAME=だ・です
DEMO_SLICE_EMAILS=lluan@andrew.cmu.edu

# Optional: override grammar per email when allowlist has multiple testers:
# DEMO_SLICE_EMAIL_GRAMMAR_MAP=lluan@andrew.cmu.edu:だ・です,other@school.edu:てください

# Optional: tidy this user’s DB to a single progress row (public DATABASE_URL):
# USER_EMAIL=lluan@andrew.cmu.edu GRAMMAR_NAME=だ・です npm run prune-user-grammar -- --apply
